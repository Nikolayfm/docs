{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "lifeyt",
  "colors": {
    "primary": "#ff9523",
    "light": "#ff9523",
    "dark": "#ff9523"
  },
  "favicon": {
    "light": "/images/Лого5.png",
    "dark": "/images/Лого5.png"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Blog",
          "href": "https://t.me/lifeytPeople",
          "icon": "newspaper"
        }
      ]
    },
    "dropdowns": [
      {
        "dropdown": "Тест",
        "tabs": [
          {
            "tab": "Начало",
            "groups": [
              {
                "group": "Start",
                "pages": [
                  "index",
                  "basics",
                  "development"
                ]
              },
              {
                "group": "Доходность",
                "pages": [
                  "essentials/settings",
                  "essentials/navigation"
                ]
              },
              {
                "group": "Интеграции",
                "pages": [
                  "essentials/markdown",
                  "essentials/code",
                  "essentials/images",
                  "essentials/reusable-snippets"
                ]
              }
            ]
          },
          {
            "tab": "API платежей",
            "groups": [
              {
                "group": "API documentation",
                "hidden": true,
                "pages": [
                  "api-reference/introduction"
                ]
              },
              {
                "group": "Endpoint examples",
                "pages": [
                  "api-reference/endpoint/get",
                  "api-reference/endpoint/create",
                  "api-reference/endpoint/delete",
                  "api-reference/endpoint/webhook"
                ]
              },
              {
                "group": "для tg-ботов (и мини-аппов)",
                "icon": "telegram-plane",
                "pages": []
              },
              {
                "group": "для web",
                "icon": "chrome",
                "pages": []
              }
            ]
          },
          {
            "tab": "История"
          },
          {
            "tab": "Ссылки и контакты"
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/dark_2x_black_text.png",
    "dark": "/images/dark_2x_cropped.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://telegram.me/Sunrise2World"
      }
    ],
    "primary": {
      "type": "button",
      "label": "chat",
      "href": "https://t.me/lifeyt_chat_pro_token"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "telegram": "https://telegram.me/lifeyt"
    }
  },
  "description": "Ruble stablecoin for telegram usage | LIFEYT"
}
